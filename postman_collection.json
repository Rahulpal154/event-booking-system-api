{
  "info": {
    "name": "Event Booking System",
    "description": "Postman collection for the Event Booking System API (Junior Node.js Developer Selection Test)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "GET /events - List upcoming events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "POST /events - Create event (valid)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tech Summit 2026\",\n  \"description\": \"Annual technology conference\",\n  \"date\": \"2026-06-15T09:00:00\",\n  \"total_capacity\": 200\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "POST /events - Create event (validation error - past date)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Old Event\",\n  \"date\": \"2020-01-01T09:00:00\",\n  \"total_capacity\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "POST /events/:id/attendance - Record attendance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_code\": \"REPLACE_WITH_BOOKING_CODE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/1/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["events", "1", "attendance"]
            }
          },
          "response": []
        },
        {
          "name": "POST /events/:id/attendance - Invalid code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_code\": \"invalid-code-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/1/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["events", "1", "attendance"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST /bookings - Book a ticket (valid)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          },
          "response": []
        },
        {
          "name": "POST /bookings - Duplicate booking (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          },
          "response": []
        },
        {
          "name": "POST /bookings - User not found (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 9999,\n  \"event_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          },
          "response": []
        },
        {
          "name": "POST /bookings - Validation error (missing field)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /users/:id/bookings - Get user bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/1/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1", "bookings"]
            }
          },
          "response": []
        },
        {
          "name": "GET /users/:id/bookings - User not found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/9999/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "9999", "bookings"]
            }
          },
          "response": []
        },
        {
          "name": "GET /users/:id/bookings - Invalid ID (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/abc/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "abc", "bookings"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
